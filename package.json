{
  "name": "paperflow-react-native-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production expo start",
    "android:go": "cross-env NODE_ENV=development expo start --android",
    "ios:go": "cross-env NODE_ENV=development expo start --ios",
    "android": "cross-env NODE_ENV=development expo run:android",
    "ios": "cross-env NODE_ENV=development expo run:ios",
    "web": "cross-env NODE_ENV=development expo start --web",
    "prebuild": "cross-env NODE_ENV=production expo prebuild",
    "build:apk": "cd android && gradlew assembleRelease"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.3.0",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/elements": "^2.9.5",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "axios": "^1.13.4",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-file-system": "~18.0.12",
    "expo-image-picker": "~17.0.10",
    "expo-local-authentication": "~16.0.4",
    "expo-secure-store": "~15.0.2",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "fast-xml-parser": "^5.2.0",
    "firebase": "^11.6.0",
    "json-server": "^0.17.4",
    "json-server-auth": "^2.1.0",
    "react": "19.1.0",
    "react-hook-form": "^7.56.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "private": true,
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
